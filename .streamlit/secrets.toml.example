# Copy to .streamlit/secrets.toml LOCALLY (gitignored) or paste into
# Streamlit Cloud App Settings → Secrets for the deployed app.

# ─── Supabase Postgres connection ─────────────────────────────────────
# From Supabase → Project Settings → Database → Connection string (URI mode).
# Replace [YOUR-PASSWORD] with the database password you set when creating
# the project.
DATABASE_URL = "postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxxxxxx.supabase.co:5432/postgres"

# ─── Anthropic (for AI Insights) ──────────────────────────────────────
ANTHROPIC_API_KEY = "sk-ant-..."

# ─── Gmail OAuth token (for auto-import) ──────────────────────────────
# After reconnecting Gmail LOCALLY (Settings → Data Import → Reconnect),
# copy the entire contents of ./token.json and paste here as a triple-quoted
# TOML string. The app reads this when running on Streamlit Cloud (where the
# local OAuth browser flow can't work).
gmail_token = """
{
  "token": "ya29...",
  "refresh_token": "1//...",
  "token_uri": "https://oauth2.googleapis.com/token",
  "client_id": "...",
  "client_secret": "...",
  "scopes": [
    "https://www.googleapis.com/auth/gmail.readonly",
    "https://www.googleapis.com/auth/gmail.send"
  ],
  "expiry": "2026-12-31T00:00:00.000000Z"
}
"""
